{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "attachment-optimizer@muchaelectric",
      "strict_min_version": "128.0",
      "strict_max_version": "151.*"
    }
  },
  "name": "Attachment Optimizer",
  "version": "0.2.0",
  "description": "Kompresuje obrazy przeciągnięte do wiadomości (WebP, auto-skalowanie)",
  "permissions": ["compose", "storage"],
  "icons": {
    "32": "assets/icon32.png",
    "64": "assets/icon64.png",
    "128": "assets/icon128.png"
  },
  "browser_action": {
    "default_title": "Attachment Optimizer — włącz/wyłącz",
    "default_icon": "assets/icon-on.svg",
    "default_label": ""
  },
  "background": {
    "scripts": [
      "libs/pdf.min.js",
      "libs/pdf-lib.min.js",
      "background.js"
    ]
  }
}
